{
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/elearning", "destination": "/elearning.html" },
    { "source": "/sales-builder", "destination": "/sales-builder.html" },
    { "source": "/client-care", "destination": "/client-care.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
