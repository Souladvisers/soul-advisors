{
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/funds",          "destination": "/funds.html" },
    { "source": "/elearning",      "destination": "/elearning.html" },
    { "source": "/estate-planning","destination": "/estate-planning.html" },
    { "source": "/financial-planning","destination": "/financial-planning.html" },
    { "source": "/factfinding",    "destination": "/factfinding.html" },
    { "source": "/islamic-finance","destination": "/islamic-finance.html" },
    { "source": "/sales-builder",  "destination": "/sales-builder.html" },
    { "source": "/client-care",    "destination": "/client-care.html" },
    { "source": "/(.*)",           "destination": "/index.html" }
  ]
}
